# ================= SYSTEM =================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=INFO

# ================= API =================
BACKEND_URL=https://YOUR_RENDER_BACKEND_URL.onrender.com
FRONTEND_URL=https://your-vercel-frontend.vercel.app
ALLOWED_HOSTS=YOUR_RENDER_BACKEND_URL.onrender.com,your-vercel-frontend.vercel.app

# ================= DATABASE =================
# Use PostgreSQL on Render (update with your actual connection string)
DATABASE_URL=postgresql://user:password@host:5432/roshni

# ================= ALGORAND =================
ALGORAND_NETWORK=testnet
ALGORAND_NODE_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_ADMIN_MNEMONIC=your-algorand-mnemonic-here
SUN_ASA_ID=756341116

# ================= ELEVENLABS VOICE =================
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ================= GEMINI AI =================
GEMINI_API_KEY=your-gemini-api-key-here

# ================= DISCOM CONFIG =================
DISCOM_FIXED_CHARGE=100.0
DISCOM_ADMIN_FEE_PERCENT=2.0
DISCOM_EXPORT_RATE=8.0
DISCOM_GRID_RATE=12.0

# ================= SOLAR PRICING =================
SOLAR_EXPORT_RATE=10.0
SOLAR_POOL_RATE=9.0

# ================= IOT =================
IOT_AUTH_TOKEN=your-secure-iot-token-here
